{
  "name": "promo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint src tests .storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui",
    "test:e2e-docker": "docker run -it -v ${PWD}:/app --workdir /app -p 9323:9323 --rm mcr.microsoft.com/playwright:v1.57.0-noble sh -lc 'npm i && npm run test:e2e -- \"$@\"' --",
    "lint:fix": "prettier --write . && eslint src tests .storybook --fix"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.0",
    "@eslint/compat": "^1.2.5",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.56.1",
    "@poppanator/sveltekit-svg": "^6.0.0",
    "@storybook/addon-a11y": "^9.1.0",
    "@storybook/addon-docs": "^9.1.0",
    "@storybook/addon-svelte-csf": "^5.0.7",
    "@storybook/addon-vitest": "^9.1.0",
    "@storybook/sveltekit": "^9.1.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/node": "^22.19.17",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-storybook": "^9.1.19",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^16.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.3.3",
    "sass": "^1.89.2",
    "storybook": "^9.1.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "uuid": "^13.0.0",
    "vite": "^7.0.4",
    "vite-plugin-devtools-json": "^1.0.0"
  },
  "dependencies": {
    "@admiral-ds/fonts": "^2.0.0",
    "@admiral-ds/icons": "^4.5.0",
    "@admiral-ds/react-ui": "^8.62.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  }
}
